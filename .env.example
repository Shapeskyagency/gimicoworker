# ─── GimiCoworker Configuration ──────────────────────────
# Note: API keys are saved via `gimi setup`. These env vars are optional overrides.

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Moonshot/Kimi (https://platform.moonshot.cn/console/api-keys)
MOONSHOT_API_KEY=

# Telegram Bot Token (optional - from @BotFather)
TELEGRAM_BOT_TOKEN=
